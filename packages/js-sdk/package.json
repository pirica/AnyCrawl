{
    "name": "@anycrawl/js-sdk",
    "version": "0.0.4",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/any4ai/AnyCrawl.git"
    },
    "type": "module",
    "private": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "tsc --watch",
        "build": "tsc -p tsconfig.build.json",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "test": "NODE_OPTIONS=--experimental-vm-modules dotenv-run -r ../.. -- jest --testPathIgnorePatterns='e2e\\.live' --detectOpenHandles --forceExit",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules dotenv-run -r ../.. -- jest --watch --detectOpenHandles",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules dotenv-run -r ../.. -- jest --coverage --testPathIgnorePatterns='e2e\\.live' --detectOpenHandles --forceExit",
        "test:e2e": "NODE_OPTIONS=--experimental-vm-modules dotenv-run -r ../.. -- jest --testPathPattern='e2e\\.live' --detectOpenHandles --forceExit"
    },
    "dependencies": {
        "axios": "^1.7.7"
    },
    "devDependencies": {
        "@dotenv-run/cli": "^1.3.6",
        "typescript": "^5.7.2",
        "@jest/globals": "^29.7.0",
        "@anycrawl/typescript-config": "workspace:*",
        "jest": "^29.7.0",
        "@types/jest": "^29.5.14",
        "ts-jest": "^29.3.2",
        "@types/node": "^22.7.4"
    }
}
